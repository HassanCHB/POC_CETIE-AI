# ── Secrets — NEVER commit ─────────────────────────────────────
.env
*.env
poc/.env
*.pem
*.key

# ── Raw client data — stays local, not needed in production ────
yearly_data/
AI-Project-for-CETIE*
DEVIS*.xlsm
DEVIS*.xlsx
~$*

# ── Node / build artefacts (from root tooling) ─────────────────
node_modules/
package-lock.json
*.tsbuildinfo

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Runtime state files (let server create fresh on first run) ─
poc/data/feedback.json
poc/data/history.json
poc/data/learned_rules.json
poc/data/sessions.json
poc/data/eval_report*.json

# ── ChromaDB vector index (binary, exceeds GitHub 100 MB limit) ─
# In production it lives on the Render persistent disk — see CETIE_CHROMA_DIR
# in render.yaml. Locally it's regenerated on demand via `python3 poc/rag.py`.
poc/chroma_db/

# ── IDE / OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Local-only misc ────────────────────────────────────────────
*.log
*.tmp
tmp/
