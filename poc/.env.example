# CETIE AI Configurator — environment variables template
#
# Copy this file to poc/.env and fill in your real keys:
#     cp poc/.env.example poc/.env
#
# poc/.env is gitignored — your actual keys never leave your laptop.
# Render uses its own dashboard env vars, NOT this file.

# ── Required: API keys ───────────────────────────────────────────────
# OpenAI — used for text-embedding-3-small (RAG embeddings).
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — used for Claude Sonnet (extraction) + Claude Opus (configuration).
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...


# ── Optional: state directory overrides (production only) ────────────
# These are set automatically on Render via render.yaml. You should leave
# them unset locally so the app falls back to poc/data/ and poc/chroma_db/
# for dev work.
#
# CETIE_STATE_DIR=/var/cetie-state
# CETIE_CHROMA_DIR=/var/cetie-state/chroma_db
